<% layout("/layouts/boilerplate")%>
    <div class="row">
        <div class="col-8 offset-2">

            <body>
                <h3
                    style="text-align: center; font-family: 'Times New Roman', Times, serif; font-weight: 700; font-size:1.98rem;">
                    Create a Listing</h3>
                <form method="Post" action="/listings/new" novalidate class="needs-validation">

                    <div class="mb-3">
                        <label for="title">Title:</label>
                        <input type="text" id="title" name="title" placeholder="Enter Title name" class="form-control"
                            required>
                        <div class="valid-feedback">Look Nice</div>
                        <div class="invalid-feedback">Please Enter the Name</div>
                    </div>

                    <div class="mb-3">
                        <label for="descrip">Description: </label>
                        <textarea type="text" id="descrip" name="description" placeholder="Enter Description"
                            class="form-control" required></textarea>
                        <div class="invalid-feedback">Please Enter Short Description about place</div>
                    </div>






                    <div class="mb-3">
                        <label for="image">Image-Url :</label>
                        <input type="url" id="image" name="url" placeholder="Enter url" class="form-control">
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="price">Price :</label>
                            <input id="price" name="price" placeholder="Enter Price" class="form-control" required>
                            <div class="invalid-feedback">Enter Valid Price</div>
                            <!-- type="number" -->

                        </div>

                        <div class="mb-3 col-md-8">
                            <label for="location">Location :</label>
                            <input type="text" id="location" name="location" placeholder="Enter Location"
                                class="form-control" required>
                            <div class="invalid-feedback"> Please provide valid Location</div>

                            <!-- <br> -->
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="country">Country :</label>
                        <input type="text" id="country" name="country" placeholder="Enter Country" class="form-control"
                            required>
                        <div class="invalid-feedback">Country Name should be valid </div>
                    </div>



                    <div class="d-flex justify-content-between mt-4">


                        <a href="/listings" class="btn btn-dark  col-2">
                            Back
                        </a>
                        <button type="reset" class="btn btn-dark col-2">
                            Reset
                        </button>
                        <button class="btn btn-dark  add-btn col-2">
                            Submit
                        </button>



                    </div>

                </form>
            </body>

            </html>
        </div>

    </div>