<% layout("/layouts/boilerplate") %>

    <div>
        <h3 class="text-center">Listing Details</h3>
    </div>




    <body>
        <div class="card mx-auto" style="width:65vw;">
            <img src="<%= list.image.url || 'https://images.pexels.com/photos/29511872/pexels-photo-29511872.jpeg' %>"
                class="card-img-top show-img" alt="listing-image">
            <div class="card-body">
                <h5 class="card-title">
                    <%=list.title%>
                </h5>
                <p class="card-text">
                    <%=list.description%>
                </p>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">Price : ₹<%= list.price?.toLocaleString("en-IN") || "N/A" %> /night</li>
                <li class="list-group-item">
                    <%=list.location%>
                </li>
                <li class="list-group-item">
                    <%=list.country%>
                </li>
            </ul>
            <div class="card-body d-flex justify-content-between align-items-center">

                <!-- Edit -->
                <a href="/listings/<%= list._id %>/edit" class="btn btn-outline-primary btn-sm">
                    Edit
                </a>

                <!-- Delete -->
                <form method="POST" action="/listings/<%= list._id %>?_method=DELETE" style="display:inline;"
                    onsubmit="return confirm('Are you sure you want to delete this listing?');">

                    <button class="btn btn-danger btn-sm" type="submit">
                        Delete
                    </button>
                </form>

            </div>


            <!-- <div class="mb-3">

                <h4>Leave A Review</h4>
                <form action="/listings/<%= list._id %>/reviews" method="POST" novalidate class="needs-validation">
                    <div class="mb-3 mt-3">
                        <label for="rating" class="form-label">Rating</label>
                        <input type="range" min="1" max="5" , id="rating" , name="review[rating]" class="form-range">

                    </div>
                    <div class="mb-3 mt-3">
                        <label for="comment" class="form-label">Comment: </label>
                        <textarea name="review[comment]" id="comment" rows="7" cols="28"
                            class="form-control" required></textarea>
                            <div class="invalid-feedback">Please Add Some Comment for Review</div>
                    </div>
                    <button class="btn btn-outline-dark ">
                        Submit
                    </button>



                </form>
            </div> -->




        </div>
        <div class="card shadow-sm p-4 mt-4 review-card">
            <h4 class="mb-4 text-center">Leave a Review</h4>

            <form action="/listings/<%= list._id %>/reviews" method="POST" novalidate class="needs-validation">

                <div class="mb-4">
                    <label for="rating" class="form-label fw-bold">Rating</label>

                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">

                    <div class="d-flex justify-content-between">
                        <small>1 ⭐</small>
                        <small>2 ⭐</small>
                        <small>3 ⭐</small>
                        <small>4 ⭐</small>
                        <small>5 ⭐</small>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label fw-bold">
                        Comment
                    </label>

                    <textarea name="review[comment]" id="comment" rows="4" class="form-control"
                        placeholder="Share your experience..." required></textarea>

                    <div class="invalid-feedback">
                        Please add a comment for your review.
                    </div>
                </div>

                <button class="btn btn-dark w-100">
                    Submit Review
                </button>

            </form>
            <hr>



            <h3 class="review-title">
                ⭐ 5.0 · <%= list.reviews.length %> Reviews
            </h3>

            <div class="reviews-container">

                <% for(let review of list.reviews){ %>

                    <div class="review-item">

                        <div class="review-user-section">
                            <div class="review-avatar">
                                <%= "G" %>
                            </div>



                            <div>
                                <h5 class="review-user-name">Guest User</h5>
                                <p class="review-user-info">Recently reviewed</p>
                            </div>
                        </div>


                        <div class="review-meta">
                            <% for(let i=0; i<review.rating; i++){ %>
                                ⭐
                                <% } %>
                                    <span class="review-date"> · Recently</span>
                        </div>

                        <p class="review-comment">
                            <%= review.comment %>
                        </p>




                    </div>

                    <form action="/listings/<%= list._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                        <input type="hidden" name="_method" value="DELETE">
                        <button class="btn btn-sm btn-dark">
                            Delete
                        </button>
                    </form>




                    <hr>

                    <% } %>




            </div>




        </div>
    </body>
    </div>